# =============================================================================
# Lumina Orchestrator — Environment Configuration
# =============================================================================
# Copy this file to ".env" and adjust the values.
# The ".env" file is in .gitignore — never commit it.
# =============================================================================

# ---------------------------------------------------------------------------
# HOST_DRIVE_PATH — Path to the documents folder ON THE HOST (physical machine).
# Docker will map this folder to /app/data inside the container.
# ---------------------------------------------------------------------------

# Example: local project folder (default if not defined)
# HOST_DRIVE_PATH=./src/Lumina.Engine/data

# Example: Google Drive for Desktop in Mirror mode (Windows)
# HOST_DRIVE_PATH=C:\Users\YourName\Google Drive\Lumina

# Example: OneDrive with "Available offline" enabled (Windows)
# HOST_DRIVE_PATH=C:\Users\YourName\OneDrive\Lumina

# Example: iCloud Drive (macOS, with "Keep on Mac" enabled)
# HOST_DRIVE_PATH=/Users/yourname/Library/Mobile Documents/com~apple~CloudDocs/Lumina

# Example: NFS mount / Linux file server
# HOST_DRIVE_PATH=/mnt/nfs/lumina_docs

HOST_DRIVE_PATH=./src/Lumina.Engine/data
